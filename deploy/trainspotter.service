[Unit]
Description=Trainspotter Telegram Bot — Italo Treno price checker
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/trainspotter
Environment=PYTHONPATH=/home/pi/trainspotter/src
ExecStart=/home/pi/trainspotter/.venv/bin/python -m trainspotter.bot
Restart=on-failure
RestartSec=30

[Install]
WantedBy=multi-user.target
